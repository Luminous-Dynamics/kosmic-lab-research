# Docker Compose/.env example for Historical K API

# API container port mapping
API_PORT=8052

# API behavior tuning
KOSMIC_API_ETAG=weak
KOSMIC_API_CACHE_SECONDS=120
# Allow CORS from dashboards/frontends (comma-separated)
# KOSMIC_API_CORS_ORIGINS=http://localhost:8050
# Strict readiness (503 until required artifacts exist)
# KOSMIC_API_STRICT_READY=1
# Structured JSON logs
# KOSMIC_API_LOG_JSON=1
# Optional shared secret (protects non-public endpoints)
# KOSMIC_API_TOKEN=secret
# Public, unauthenticated paths (comma-separated)
# KOSMIC_API_PUBLIC_PATHS=/health,/ready,/meta,/info,/docs,/redoc
# Per-client rate limit (requests per window; window seconds)
# KOSMIC_API_RATE_LIMIT=60
# KOSMIC_API_RATE_WINDOW=60

# Logs directory inside container (compose mounts ./logs to /app/logs)
KOSMIC_LOGS_DIR=/app/logs

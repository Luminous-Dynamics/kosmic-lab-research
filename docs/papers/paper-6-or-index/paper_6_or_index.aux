\@writefile{lof}{\contentsline {figure}{\numberline {17}{\ignorespaces \textbf  {Algorithm Comparison.} O/R Index correlation with coordination success across three policy gradient algorithms. REINFORCE and A2C show strong correlations ($r = -0.71$*** and $r = -0.88$*** respectively), while PPO shows weaker correlation ($r = -0.34$, n.s.), motivating the OR-PPO adaptive control approach.}}{53}{figure.17}\protected@file@percent }
\newlabel{fig:s1_algorithms}{{17}{53}{\textbf {Algorithm Comparison.} O/R Index correlation with coordination success across three policy gradient algorithms. REINFORCE and A2C show strong correlations ($r = -0.71$*** and $r = -0.88$*** respectively), while PPO shows weaker correlation ($r = -0.34$, n.s.), motivating the OR-PPO adaptive control approach}{figure.17}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {18}{\ignorespaces \textbf  {O/R Index Evolution During Training.} O/R values \textit  {decrease} as training progresses, indicating policies become more consistent. The magnitude of correlation with final performance grows over training ($|r| = 0.52$ at ep5, $0.69$ at ep10, $0.85$ at ep30). Early O/R predicts eventual success; lower O/R at any timepoint correlates with higher final coordination.}}{53}{figure.18}\protected@file@percent }
\newlabel{fig:s2_temporal}{{18}{53}{\textbf {O/R Index Evolution During Training.} O/R values \textit {decrease} as training progresses, indicating policies become more consistent. The magnitude of correlation with final performance grows over training ($|r| = 0.52$ at ep5, $0.69$ at ep10, $0.85$ at ep30). Early O/R predicts eventual success; lower O/R at any timepoint correlates with higher final coordination}{figure.18}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {19}{\ignorespaces \textbf  {Hyperparameter Robustness.} O/R Index maintains strong predictive power across variations in history window length (25--100 timesteps), message dimensions (3--10), and observation noise levels (0.05--0.5). All configurations achieve $|r| > 0.55$, demonstrating robustness to implementation choices.}}{54}{figure.19}\protected@file@percent }
\newlabel{fig:s3_ablations}{{19}{54}{\textbf {Hyperparameter Robustness.} O/R Index maintains strong predictive power across variations in history window length (25--100 timesteps), message dimensions (3--10), and observation noise levels (0.05--0.5). All configurations achieve $|r| > 0.55$, demonstrating robustness to implementation choices}{figure.19}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {20}{\ignorespaces \textbf  {Statistical Power Analysis.} Power curves for detecting O/R-coordination correlation at various sample sizes. At $n = 30$ teams, power exceeds 99\% for our observed effect size ($r = -0.70$). Even $n = 11$ achieves 80\% power, enabling rapid early-stage diagnostics with minimal computational cost.}}{54}{figure.20}\protected@file@percent }
\newlabel{fig:s4_power}{{20}{54}{\textbf {Statistical Power Analysis.} Power curves for detecting O/R-coordination correlation at various sample sizes. At $n = 30$ teams, power exceeds 99\% for our observed effect size ($r = -0.70$). Even $n = 11$ achieves 80\% power, enabling rapid early-stage diagnostics with minimal computational cost}{figure.20}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {21}{\ignorespaces \textbf  {Summary Dashboard.} Six-panel overview of main results: (A) O/R vs.\ coordination scatter, (B) metric comparison, (C) temporal evolution, (D) robustness conditions, (E) algorithm comparison, (F) power analysis. This dashboard provides a comprehensive view of O/R Index performance across all experimental conditions.}}{55}{figure.21}\protected@file@percent }
\newlabel{fig:s5_summary}{{21}{55}{\textbf {Summary Dashboard.} Six-panel overview of main results: (A) O/R vs.\ coordination scatter, (B) metric comparison, (C) temporal evolution, (D) robustness conditions, (E) algorithm comparison, (F) power analysis. This dashboard provides a comprehensive view of O/R Index performance across all experimental conditions}{figure.21}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {22}{\ignorespaces \textbf  {Discovery vs.\ Execution Phases.} O/R Index is most predictive during the ``discovery'' phase when agents are learning coordination strategies. In ``execution'' tasks where optimal behavior is known, behavioral variance naturally converges, reducing O/R's discriminative power. This explains the theoretical framework's task-dependency predictions (Section~\ref {subsec:why_succeeds}).}}{56}{figure.22}\protected@file@percent }
\newlabel{fig:s6_discovery}{{22}{56}{\textbf {Discovery vs.\ Execution Phases.} O/R Index is most predictive during the ``discovery'' phase when agents are learning coordination strategies. In ``execution'' tasks where optimal behavior is known, behavioral variance naturally converges, reducing O/R's discriminative power. This explains the theoretical framework's task-dependency predictions (Section~\ref {subsec:why_succeeds})}{figure.22}{}}
\@writefile{toc}{\contentsline {section}{\numberline {K}Code Availability}{56}{appendix.K}\protected@file@percent }
\citation{terry2021pettingzoo}
\@writefile{lof}{\contentsline {figure}{\numberline {16}{\ignorespaces \textbf  {Decision Tree: When and How to Use O/R Index.} Practitioners should first determine if their task involves multi-agent coordination. If yes, the O/R Index can serve four primary use cases: \textbf  {(1) Debugging:} Compute O/R for failed teams to identify behavioral inconsistency; high O/R indicates erratic behavior that hinders coordination. \textbf  {(2) Early Stopping:} Measure O/R at episode 10 to predict final performance ($r = -0.69$***), enabling faster iteration. \textbf  {(3) Algorithm Selection:} Compare O/R correlation across candidate algorithms (e.g., REINFORCE vs PPO); choose the algorithm with strongest O/R-performance correlation. \textbf  {(4) Training Optimization:} Use CR-REINFORCE or OR-PPO to directly improve coordination by 6-9\%. Computational requirements are minimal ($<$1s per 100 trajectories), and 30+ team samples provide adequate statistical power. For interpretation, O/R values below -0.5 indicate strong coordination, while values near or above 0 suggest coordination failure.}}{60}{figure.16}\protected@file@percent }
\newlabel{fig:decision_tree}{{16}{60}{\textbf {Decision Tree: When and How to Use O/R Index.} Practitioners should first determine if their task involves multi-agent coordination. If yes, the O/R Index can serve four primary use cases: \textbf {(1) Debugging:} Compute O/R for failed teams to identify behavioral inconsistency; high O/R indicates erratic behavior that hinders coordination. \textbf {(2) Early Stopping:} Measure O/R at episode 10 to predict final performance ($r = -0.69$***), enabling faster iteration. \textbf {(3) Algorithm Selection:} Compare O/R correlation across candidate algorithms (e.g., REINFORCE vs PPO); choose the algorithm with strongest O/R-performance correlation. \textbf {(4) Training Optimization:} Use CR-REINFORCE or OR-PPO to directly improve coordination by 6-9\%. Computational requirements are minimal ($<$1s per 100 trajectories), and 30+ team samples provide adequate statistical power. For interpretation, O/R values below -0.5 indicate strong coordination, while values near or above 0 suggest coordination failure}{figure.16}{}}
\gdef \@abspage@last{60}

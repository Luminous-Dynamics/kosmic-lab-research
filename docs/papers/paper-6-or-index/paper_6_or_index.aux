\@writefile{lof}{\contentsline {figure}{\numberline {14}{\ignorespaces \textbf  {OR-PPO Learning Dynamics (Sparse Reward).} Comparison of vanilla PPO (blue) vs OR-PPO (red) on Overcooked-AI cramped\_room across 3 seeds. Left: Total reward curves showing identical 0.40 shaped reward (zero actual task completions). Right: O/R Index evolution converging to $\approx -0.045$ for both algorithms (PPO: $-0.0447 \pm 0.0098$, OR-PPO: $-0.0447 \pm 0.0004$). Note the substantially narrower confidence interval for OR-PPO, indicating 24$\times $ more stable learning dynamics. Shaded regions show standard deviation across seeds. }}{47}{figure.14}\protected@file@percent }
\newlabel{fig:or_ppo_comparison}{{14}{47}{\textbf {OR-PPO Learning Dynamics (Sparse Reward).} Comparison of vanilla PPO (blue) vs OR-PPO (red) on Overcooked-AI cramped\_room across 3 seeds. Left: Total reward curves showing identical 0.40 shaped reward (zero actual task completions). Right: O/R Index evolution converging to $\approx -0.045$ for both algorithms (PPO: $-0.0447 \pm 0.0098$, OR-PPO: $-0.0447 \pm 0.0004$). Note the substantially narrower confidence interval for OR-PPO, indicating 24$\times $ more stable learning dynamics. Shaded regions show standard deviation across seeds}{figure.14}{}}

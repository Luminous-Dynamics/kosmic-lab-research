\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces \textbf  {Causal Mediation Analysis.} Observation noise causally affects coordination performance \emph  {primarily through} the O/R Index ($a \times b = -0.81$, 73\% of total effect), with negligible direct effect ($c' = -0.01$, n.s.). This establishes that behavioral consistency, as measured by O/R, is the causal mechanism linking observation quality to coordination success.}}{12}{figure.4}\protected@file@percent }
\newlabel{fig:causal_mediation}{{4}{12}{\textbf {Causal Mediation Analysis.} Observation noise causally affects coordination performance \emph {primarily through} the O/R Index ($a \times b = -0.81$, 73\% of total effect), with negligible direct effect ($c' = -0.01$, n.s.). This establishes that behavioral consistency, as measured by O/R, is the causal mechanism linking observation quality to coordination success}{figure.4}{}}
